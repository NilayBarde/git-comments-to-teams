# Users are loaded from users.json (primary) or this env var (fallback)
# USERS_CONFIG='[{"name":"your-name","teamsWebhookUrl":"https://...","gitlab":{"username":"you","userId":12345}}]'

# Optional: webhook secrets for verification
GITHUB_WEBHOOK_SECRET=
GITLAB_WEBHOOK_TOKEN=

# Optional: known repos (comma-separated, prefix with github: or gitlab:)
# New repos are auto-discovered from incoming webhooks
WATCHED_REPOS=gitlab:group/project-one,gitlab:group/project-two,github:org/repo

# Self-service registration: GitHub API (for committing users.json on register)
GITHUB_TOKEN=your-github-personal-access-token
GITHUB_REPO=owner/repo-name

# Optional: server port (default: 3000)
PORT=3000