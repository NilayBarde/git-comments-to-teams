# Persistence backend: 'local' (default), 'github', or 'gitlab'
# Auto-detected from available tokens if not set explicitly
# PERSISTENCE_BACKEND=local

# GitHub backend (for persisting users.json/repos.json to a GitHub repo)
GITHUB_TOKEN=your-github-personal-access-token
GITHUB_REPO=owner/repo-name

# GitLab backend (for persisting to a GitLab repo)
# GITLAB_TOKEN=your-gitlab-project-access-token
# GITLAB_PROJECT_ID=12345
# GITLAB_URL=https://gitlab.disney.com

# Webhook secrets for verification (optional)
GITHUB_WEBHOOK_SECRET=
GITLAB_WEBHOOK_TOKEN=

# Admin webhook for health alerts (optional)
# ADMIN_WEBHOOK_URL=https://your-admin-teams-webhook-url

# Server port (default: 3000)
PORT=3000

# AWS Lambda / DynamoDB (set DYNAMODB_TABLE to enable DynamoDB storage)
# DYNAMODB_TABLE=pr-notifier

# Base URL for notification card links (defaults to Render URL)
# BASE_URL=https://your-api-gateway-url.execute-api.us-east-1.amazonaws.com

# Basic auth for UI pages (optional, webhook endpoints are always open)
# BASIC_AUTH_USER=admin
# BASIC_AUTH_PASS=your-password
