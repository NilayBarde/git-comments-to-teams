# Users configuration (required)
# JSON array of user configs - each user has their own Teams webhook
USERS_CONFIG='[{"name":"your-name","teamsWebhookUrl":"https://your-teams-webhook-url","github":{"username":"your-github-username"},"gitlab":{"username":"your-gitlab-username","userId":12345},"mentionAliases":["team-alias-1","team-alias-2"]}]'

# Optional: webhook secrets for verification
GITHUB_WEBHOOK_SECRET=
GITLAB_WEBHOOK_TOKEN=

# Optional: known repos (comma-separated, prefix with github: or gitlab:)
# New repos are auto-discovered from incoming webhooks
WATCHED_REPOS=gitlab:group/project-one,gitlab:group/project-two,github:org/repo

# Optional: server port (default: 3000)
PORT=3000